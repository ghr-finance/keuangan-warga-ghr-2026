rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions & Helpers
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Special: Admin Check (Bootstrapped for the requesting user)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'semestasetiawan20@gmail.com'
      );
    }

    // Entity Validation Blueprints
    function isValidWarga(data) {
      return data.nama is string && data.nama.size() > 0 && data.nama.size() <= 200 &&
             data.noRumah is string && data.noRumah.size() > 0 &&
             data.status in ['Aktif', 'Non-Aktif'] &&
             data.statusHuni in ['Menghuni', 'Tidak Menghuni'];
    }

    function isValidKategori(data) {
      return data.nama is string && data.nama.size() > 0 && data.nama.size() <= 200 &&
             data.tipe in ['pemasukan', 'pengeluaran'];
    }

    function isValidTransaksi(data) {
      return data.jumlah is number && data.jumlah >= 0 &&
             data.tipe in ['pemasukan', 'pengeluaran'] &&
             data.kategoriId is string &&
             data.keterangan is string && data.keterangan.size() <= 1000;
    }

    function isValidTunggakan(data) {
      return data.wargaId is string &&
             data.nama is string && data.nama.size() > 0 &&
             data.totalBulan is number &&
             data.nominalPerBulan is number &&
             data.totalTagihan is number &&
             data.nominalBayar is number &&
             data.sisa is number &&
             data.status in ['Macet', 'Lunas', 'Belum Lunas'];
    }

    // Rules for Collections
    match /warga/{wargaId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
      allow create: if isAdmin() && isValidWarga(incoming());
      allow update: if isAdmin() && isValidWarga(incoming());
      allow delete: if isAdmin();
    }

    match /kategori/{kategoriId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
      allow create: if isAdmin() && isValidKategori(incoming());
      allow update: if isAdmin() && isValidKategori(incoming());
      allow delete: if isAdmin();
    }

    match /transaksi/{transaksiId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
      allow create: if isAdmin() && isValidTransaksi(incoming()) && 
                    exists(/databases/$(database)/documents/kategori/$(incoming().kategoriId));
      allow update: if isAdmin() && isValidTransaksi(incoming());
      allow delete: if isAdmin();
    }

    match /tunggakan_macet/{tunggakanId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
      allow create: if isAdmin() && isValidTunggakan(incoming());
      allow update: if isAdmin() && (
        isValidTunggakan(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['nominalBayar', 'sisa', 'status', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /petugas/{petugasId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /backups/{backupId} {
      allow read, write: if isAdmin();
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }
  }
}
