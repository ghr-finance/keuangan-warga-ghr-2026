{
  "entities": {
    "Warga": {
      "title": "Warga",
      "description": "Data penduduk atau warga dalam lingkungan.",
      "type": "object",
      "properties": {
        "nama": { "type": "string", "description": "Nama lengkap warga" },
        "noRumah": { "type": "string", "description": "Nomor rumah atau alamat blok" },
        "phone": { "type": "string", "description": "Nomor handphone" },
        "status": { "type": "string", "enum": ["Aktif", "Non-Aktif"], "description": "Status kependudukan" },
        "statusHuni": { "type": "string", "enum": ["Menghuni", "Tidak Menghuni"], "description": "Status hunian rumah" },
        "isIuranWajib": { "type": "boolean", "description": "Apakah warga wajib membayar iuran bulanan" },
        "isIuranRT": { "type": "boolean", "description": "Apakah warga ikut serta dalam iuran RT" }
      },
      "required": ["nama", "noRumah", "status", "statusHuni"]
    },
    "Kategori": {
      "title": "Kategori",
      "description": "Kategori transaksi keuangan.",
      "type": "object",
      "properties": {
        "nama": { "type": "string" },
        "tipe": { "type": "string", "enum": ["pemasukan", "pengeluaran"] },
        "icon": { "type": "string", "description": "Nama icon lucide" }
      },
      "required": ["nama", "tipe"]
    },
    "Transaksi": {
      "title": "Transaksi",
      "description": "Catatan arus kas masuk dan keluar.",
      "type": "object",
      "properties": {
        "tanggal": { "type": "string", "format": "date-time" },
        "keterangan": { "type": "string" },
        "jumlah": { "type": "number" },
        "tipe": { "type": "string", "enum": ["pemasukan", "pengeluaran"] },
        "kategoriId": { "type": "string" },
        "wargaId": { "type": "string", "description": "ID warga jika terkait iuran" },
        "eventId": { "type": "string", "description": "ID event jika terkait kegiatan tertentu" },
        "petugasId": { "type": "string", "description": "ID petugas sebagai PIC pengeluaran" },
        "picName": { "type": "string", "description": "Nama PIC jika tidak menggunakan ID petugas" },
        "bulanIuran": { "type": "string", "description": "Format YYYY-MM jika ini adalah iuran bulanan" }
      },
      "required": ["tanggal", "jumlah", "tipe", "kategoriId"]
    },
    "Petugas": {
      "title": "Petugas",
      "description": "Data petugas atau staf pengelola.",
      "type": "object",
      "properties": {
        "nama": { "type": "string" },
        "jabatan": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["Aktif", "Non-Aktif"] }
      },
      "required": ["nama", "jabatan", "status"]
    },
    "Event": {
      "title": "Event",
      "description": "Kegiatan warga yang membutuhkan budgeting.",
      "type": "object",
      "properties": {
        "nama": { "type": "string" },
        "tanggal": { "type": "string", "format": "date-time" },
        "budget": { "type": "number" },
        "deskripsi": { "type": "string" },
        "status": { "type": "string", "enum": ["Berjalan", "Selesai"] }
      },
      "required": ["nama", "tanggal", "budget", "status"]
    },
    "TunggakanMacet": {
      "title": "Tunggakan Macet",
      "description": "Data tunggakan iuran yang berstatus macet.",
      "type": "object",
      "properties": {
        "wargaId": { "type": "string" },
        "nama": { "type": "string" },
        "totalBulan": { "type": "number" },
        "nominalPerBulan": { "type": "number" },
        "totalTagihan": { "type": "number" },
        "nominalBayar": { "type": "number" },
        "sisa": { "type": "number" },
        "keterangan": { "type": "string" },
        "status": { "type": "string", "enum": ["Macet", "Lunas"] },
        "createdAt": { "type": "number" }
      },
      "required": ["wargaId", "nama", "totalBulan", "nominalPerBulan", "totalTagihan", "nominalBayar", "sisa", "keterangan", "status"]
    }
  },
  "firestore": {
    "/warga/{wargaId}": {
      "schema": "Warga",
      "description": "Koleksi data warga."
    },
    "/kategori/{kategoriId}": {
      "schema": "Kategori",
      "description": "Koleksi kategori transaksi."
    },
    "/transaksi/{transaksiId}": {
      "schema": "Transaksi",
      "description": "Koleksi arus kas."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Koleksi kegiatan warga."
    },
    "/petugas/{petugasId}": {
      "schema": "Petugas",
      "description": "Koleksi data petugas."
    },
    "/tunggakan_macet/{tunggakanId}": {
      "schema": "TunggakanMacet",
      "description": "Koleksi data tunggakan macet."
    }
  }
}
