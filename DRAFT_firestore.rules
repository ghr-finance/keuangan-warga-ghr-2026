rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Context-Aware Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Validations
    function isValidWarga(data) {
      return data.nama is string && data.nama.size() > 0 && data.nama.size() <= 100 &&
             data.noRumah is string && data.noRumah.size() > 0 && data.noRumah.size() <= 100 &&
             data.status in ['Aktif', 'Non-Aktif'] &&
             data.statusHuni in ['Menghuni', 'Tidak Menghuni'] &&
             data.isIuranWajib is bool;
    }

    function isValidKategori(data) {
      return data.nama is string && data.nama.size() > 0 && data.nama.size() <= 100 &&
             data.tipe in ['pemasukan', 'pengeluaran'];
    }

    function isValidTransaksi(data) {
      return data.tanggal is number &&
             data.jumlah is number && data.jumlah >= 0 &&
             data.tipe in ['pemasukan', 'pengeluaran'] &&
             data.kategoriId is string &&
             data.keterangan is string && data.keterangan.size() <= 500;
    }

    function isValidEvent(data) {
      return data.nama is string && data.nama.size() > 0 && data.nama.size() <= 100 &&
             data.budget is number && data.budget >= 0 &&
             data.status in ['Berjalan', 'Selesai'];
    }

    function isValidPetugas(data) {
      return data.nama is string && data.nama.size() > 0 && data.nama.size() <= 100 &&
             data.jabatan is string && data.jabatan.size() > 0 &&
             data.status in ['Aktif', 'Non-Aktif'];
    }

    function isValidTunggakan(data) {
      return data.wargaId is string &&
             data.nama is string && data.nama.size() > 0 &&
             data.totalBulan is number &&
             data.nominalPerBulan is number &&
             data.totalTagihan is number &&
             data.nominalBayar is number &&
             data.sisa is number &&
             data.keterangan is string &&
             data.status in ['Macet', 'Lunas'];
    }

    // Rules
    match /warga/{wargaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidWarga(incoming());
      allow update: if isSignedIn() && isValidWarga(incoming());
      allow delete: if isSignedIn();
    }

    match /kategori/{kategoriId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidKategori(incoming());
      allow update: if isSignedIn() && isValidKategori(incoming());
      allow delete: if isSignedIn();
    }

    match /transaksi/{transaksiId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTransaksi(incoming());
      allow update: if isSignedIn() && isValidTransaksi(incoming());
      allow delete: if isSignedIn();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidEvent(incoming());
      allow update: if isSignedIn() && isValidEvent(incoming());
      allow delete: if isSignedIn();
    }

    match /petugas/{petugasId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPetugas(incoming());
      allow update: if isSignedIn() && isValidPetugas(incoming());
      allow delete: if isSignedIn();
    }

    match /tunggakan_macet/{tunggakanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTunggakan(incoming());
      allow update: if isSignedIn() && isValidTunggakan(incoming());
      allow delete: if isSignedIn();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
